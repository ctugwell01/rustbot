# ─────────────────────────────────────────
# RustBot Environment Variables
# KEEP THIS FILE PRIVATE — never share it
# ─────────────────────────────────────────

# Get this from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Your Kick auth token — see README.md for how to get this
KICK_AUTH_TOKEN=your_kick_auth_token_here

# Your Kick XSRF token (grab alongside auth token)
KICK_XSRF_TOKEN=your_kick_xsrf_token_here
